{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "experimentalServices": {
    "web": {
      "entrypoint": ".",
      "routePrefix": "/"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.blutexts.com/api/:path*"
    }
  ]
}
